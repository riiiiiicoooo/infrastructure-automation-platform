      "targets": [
        {
          "datasource": "TimescaleDB",
          "format": "table",
          "rawSql": true,
          "refId": "A",
          "sql": "SELECT COUNT(CASE WHEN auto_remediation_executed = true THEN 1 END) as \"Auto-Remediated\", COUNT(CASE WHEN status = 'escalated' AND (SELECT COUNT(*) FROM incident_escalations WHERE incident_id = incidents.id AND escalation_level = 1) > 0 THEN 1 END) as \"Escalated to Level 1\", COUNT(CASE WHEN (SELECT COUNT(*) FROM incident_escalations WHERE incident_id = incidents.id AND escalation_level >= 2) > 0 THEN 1 END) as \"Escalated to Level 2+\" FROM incidents WHERE opened_at > now() - interval '30 days' GROUP BY 1"
        }
      ],
