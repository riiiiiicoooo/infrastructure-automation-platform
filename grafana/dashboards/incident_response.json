      "targets": [
        {
          "datasource": "TimescaleDB",
          "format": "table",
          "rawSql": true,
          "refId": "A",
          "sql": "SELECT incident_key, title, incident_type, severity, status, opened_at, COALESCE(resolved_at, now()) as resolved_at, EXTRACT(EPOCH FROM (COALESCE(resolved_at, now()) - opened_at)) / 60 as mttr_minutes, CASE WHEN auto_remediation_executed THEN 'Auto-Remediated' ELSE 'Manual' END as resolution_type FROM incidents WHERE status IN ('resolved', 'closed', 'open', 'investigating') ORDER BY opened_at DESC LIMIT 50"
        }
      ],
      "title": "Open Incidents Table (Last 50)",
      "type": "table"
