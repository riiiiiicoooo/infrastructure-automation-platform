          "datasource": "TimescaleDB",
          "format": "time_series",
          "rawSql": true,
          "refId": "A",
          "sql": "SELECT time_bucket('1 hour', opened_at) as time, AVG(EXTRACT(EPOCH FROM (COALESCE(resolved_at, now()) - opened_at)) / 60) as mttr_minutes FROM incidents WHERE opened_at > now() - interval '30 days' GROUP BY time ORDER BY time DESC"
        }
      ],
