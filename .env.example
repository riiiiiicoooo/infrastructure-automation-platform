# Infrastructure Automation Platform - Environment Configuration

# =====================================================================
# DATABASE & STORAGE
# =====================================================================

# Supabase PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/infrastructure_automation
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Redis (Caching & Job Queue)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# S3/Azure Blob for Terraform State
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
TERRAFORM_STATE_BUCKET=infrastructure-automation-tf-state

# =====================================================================
# ORCHESTRATION & AUTOMATION
# =====================================================================

# Trigger.dev (Long-Running Job Orchestration)
TRIGGER_DEV_API_KEY=your_trigger_dev_api_key
TRIGGER_DEV_ORG_ID=your_org_id
TRIGGER_DEV_PROJECT_ID=your_project_id

# n8n (Workflow Automation)
N8N_URL=http://n8n:5678
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_URL=https://your-domain.com/webhooks/n8n

# Temporal (Distributed Workflows - Optional)
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# =====================================================================
# POLICY & COMPLIANCE
# =====================================================================

# OPA (Open Policy Agent)
OPA_URL=http://opa-server:8181
OPA_POLICIES_REPO=https://github.com/your-org/opa-policies.git

# =====================================================================
# INCIDENT RESPONSE & MONITORING
# =====================================================================

# ML Classifier (Incident Type Prediction)
ML_CLASSIFIER_URL=http://ml-classifier:8000
ML_CLASSIFIER_PORT=8000
ML_MODEL_PATH=/models/incident_classifier.pkl

# Grafana
GRAFANA_URL=https://grafana.example.com
GRAFANA_API_KEY=your_grafana_api_key
GRAFANA_INCIDENT_DASHBOARD_UID=incident-response

# TimescaleDB (Time-Series Metrics)
TIMESCALEDB_URL=postgresql://user:password@timescaledb:5432/metrics

# =====================================================================
# INTEGRATIONS
# =====================================================================

# PagerDuty (Incident Management)
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_ID=your_service_id
PAGERDUTY_ESCALATION_POLICY_ID=your_policy_id

# Linear (Issue Tracking)
LINEAR_API_KEY=your_linear_api_key
LINEAR_TEAM_ID=your_team_id
LINEAR_PROJECT_ID=your_project_id

# Slack (Notifications)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_APP_ID=your_app_id
SLACK_TEAM_ID=your_team_id

# ServiceNow (Request Management)
SERVICENOW_INSTANCE_URL=https://dev12345.service-now.com
SERVICENOW_API_USERNAME=your_username
SERVICENOW_API_PASSWORD=your_password
SERVICENOW_CLIENT_ID=your_client_id
SERVICENOW_CLIENT_SECRET=your_client_secret

# Datadog (APM & Monitoring)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

# =====================================================================
# INFRASTRUCTURE PROVISIONING
# =====================================================================

# Terraform
TERRAFORM_VERSION=1.6.0
TERRAFORM_CLOUD_API_TOKEN=your_terraform_cloud_token
TERRAFORM_CLOUD_ORG=your_org

# Cloud Credentials
AWS_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/TerraformRole
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_TENANT_ID=your_tenant_id

GCP_PROJECT_ID=your_project_id
GCP_CREDENTIALS_JSON={...}

# Vault (Secrets Management)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=your_vault_token
VAULT_NAMESPACE=infrastructure

# =====================================================================
# SIMULATION & DIGITAL TWIN
# =====================================================================

# Simulation Service
SIMULATION_URL=http://simulation:8000
SIMULATION_PORT=8000
SIMULATION_CONTAINER_REGISTRY=your-registry.azurecr.io
SIMULATION_WORKLOAD_PROFILE=production

# =====================================================================
# AUTHENTICATION & SECURITY
# =====================================================================

# JWT Signing
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_ISSUER=infrastructure-automation-platform
JWT_AUDIENCE=infrastructure-platform-users
JWT_EXPIRATION=24h

# CORS
CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# =====================================================================
# OBSERVABILITY & LOGGING
# =====================================================================

# Environment
ENVIRONMENT=development
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# Sentry (Error Tracking)
SENTRY_DSN=https://your_sentry_key@sentry.io/project_id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_ENABLED=true
OTEL_JAEGER_ENDPOINT=http://jaeger:16686
OTEL_TRACES_SAMPLE_RATE=0.1

# =====================================================================
# EMAIL
# =====================================================================

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@infrastructure-platform.com
SENDGRID_FROM_NAME=Infrastructure Platform

# Email Templates
EMAIL_TEMPLATES_PATH=/src/emails
REACT_EMAIL_ENABLED=true

# =====================================================================
# API & SERVER
# =====================================================================

# Server Configuration
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=https://api.example.com

# Frontend
FRONTEND_URL=https://app.example.com
FRONTEND_PORT=3001

# =====================================================================
# FEATURE FLAGS
# =====================================================================

# Feature Toggles
FEATURE_AUTO_REMEDIATION=true
FEATURE_DIGITAL_TWIN=true
FEATURE_POLICY_ENFORCEMENT=true
FEATURE_ML_CLASSIFICATION=true
FEATURE_PROGRESSIVE_ROLLOUT=true
FEATURE_COST_OPTIMIZATION=true

# =====================================================================
# BACKUP & DISASTER RECOVERY
# =====================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=s3://backups-bucket

# =====================================================================
# SUPPORT & HELP
# =====================================================================

SUPPORT_EMAIL=support@example.com
HELP_CENTER_URL=https://help.example.com
DOCUMENTATION_URL=https://docs.example.com
GITHUB_REPO_URL=https://github.com/your-org/infrastructure-automation-platform

# =====================================================================
# Development & Testing
# =====================================================================

# Local Development
MOCK_EXTERNAL_SERVICES=false
MOCK_TERRAFORM_APPLY=false
MOCK_OPA_EVALUATION=false

# Testing
TEST_DATABASE_URL=postgresql://user:password@localhost:5433/test_db
TEST_SEED_DATA=true

# Debug
DEBUG=infrastructure-automation-platform:*
VERBOSE_LOGGING=false
